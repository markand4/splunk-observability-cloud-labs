# ─────────────────────────────────────────────────────────────
# Splunk Observability Cloud — Shared Credentials
# ─────────────────────────────────────────────────────────────
# All labs in this repo read from this file.
# Copy to .env and fill in your values. Never commit .env.

# ── Export Mode ──────────────────────────────────────────────
# Option A: OTEL Collector Gateway (recommended for production)
#   Set the collector endpoint; the collector handles auth/routing.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
#
# Option B: Direct to Splunk Ingest
#   Omit OTEL_EXPORTER_OTLP_ENDPOINT and set the token + realm.

# Your Splunk O11y Cloud ingest token (required for direct ingest only)
SPLUNK_ACCESS_TOKEN=your-splunk-ingest-token-here

# Your Splunk realm (e.g. us0, us1, us2, eu0, jp0, au0)
SPLUNK_REALM=us0

# ── Resource Attributes ─────────────────────────────────────
# Standard OTEL env var — comma-separated key=value pairs.
# These are attached to every span and metric as resource attributes.
# Add any attributes your org requires here.
# OTEL_RESOURCE_ATTRIBUTES=team.name=platform,app.tier=backend,region=us-east-1

# Override the default service name (default: set per lab)
# OTEL_SERVICE_NAME=my-service

# Environment tag used by Splunk APM to separate dev/staging/prod
# OTEL_ENVIRONMENT=demo
