# ─────────────────────────────────────────────────────────────
# Splunk Observability Cloud — Shared Credentials
# ─────────────────────────────────────────────────────────────
# All labs in this repo read from this file.
# Copy to .env and fill in your values. Never commit .env.

# Your Splunk O11y Cloud ingest token (REQUIRED)
SPLUNK_ACCESS_TOKEN=your-splunk-ingest-token-here

# Your Splunk realm (e.g. us0, us1, us2, eu0, jp0, au0)
SPLUNK_REALM=us0
